{
  "title": "StreamLake ML Observability",
  "uid": "streamlake-ml",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "tags": ["streamlake", "ml", "churn"],
  "panels": [
    {
      "id": 1,
      "title": "Predictions per Second",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(streamlake_predictions_total[1m])",
          "legendFormat": "{{ab_group}} / {{prediction}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 2,
      "title": "Prediction Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, rate(streamlake_prediction_latency_seconds_bucket[1m]))",
          "legendFormat": "p50"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, rate(streamlake_prediction_latency_seconds_bucket[1m]))",
          "legendFormat": "p95"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, rate(streamlake_prediction_latency_seconds_bucket[1m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red",    "value": 0.1  }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Churn Probability Distribution",
      "type": "histogram",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(streamlake_churn_probability_bucket[5m])",
          "legendFormat": "churn_prob"
        }
      ]
    },
    {
      "id": 4,
      "title": "A/B Split — Champion vs Challenger",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (ab_group) (streamlake_predictions_total)",
          "legendFormat": "{{ab_group}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Feature PSI Drift Scores",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 16, "w": 16, "h": 10 },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "streamlake_feature_psi",
          "legendFormat": "{{feature}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null  },
              { "color": "yellow", "value": 0.10  },
              { "color": "red",    "value": 0.25  }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Drift Alert",
      "type": "stat",
      "gridPos": { "x": 16, "y": 16, "w": 8, "h": 10 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "streamlake_drift_alert",
          "legendFormat": "Drift Alert"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "STABLE",  "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "RETRAIN", "color": "red"   } } }
          ]
        }
      }
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] }
}
