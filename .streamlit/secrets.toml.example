# Streamlit Community Cloud secrets
# Copy this file's contents into: https://share.streamlit.io > App > Settings > Secrets
# DO NOT commit the real secrets.toml — it is in .gitignore

# FastAPI endpoint deployed on Railway/Render
API_URL = "https://your-app.up.railway.app"

# AWS S3 credentials (same IAM user as the pipeline)
AWS_ACCESS_KEY_ID = "AKIA..."
AWS_SECRET_ACCESS_KEY = "..."
AWS_DEFAULT_REGION = "us-east-1"
