# ── Local MinIO (dev only) ──────────────────────────────────────────
# Comment these out when using real AWS S3
AWS_ENDPOINT_URL=http://localhost:9002
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1

# ── AWS S3 (cloud) ──────────────────────────────────────────────────
# Remove AWS_ENDPOINT_URL above and fill these in for real S3
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=us-east-1

# ── Delta Lake Paths ───────────────────────────────────────────────
DELTA_BRONZE_PATH=s3://streamlake-bronze/events
DELTA_SILVER_PATH=s3://streamlake-silver/events
DELTA_GOLD_PATH=s3://streamlake-gold
DELTA_QUARANTINE_PATH=s3://streamlake-silver/quarantine
DELTA_FEATURES_PATH=s3://streamlake-features

# ── Kafka / Redpanda (local) ────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081

# ── Redpanda Cloud (cloud) ─────────────────────────────────────────
# Get from Redpanda Cloud console > Security > SASL credentials
# KAFKA_BOOTSTRAP_SERVERS=seed-xxxx.redpanda.com:9092
# KAFKA_SASL_USERNAME=<username>
# KAFKA_SASL_PASSWORD=<password>
# SCHEMA_REGISTRY_URL=https://schema-registry-xxxx.redpanda.com
# SCHEMA_REGISTRY_API_KEY=<api-key>
# SCHEMA_REGISTRY_API_SECRET=<api-secret>

# ── Kafka Topics ───────────────────────────────────────────────────
KAFKA_TOPIC_EVENTS=streamlake.events.raw
KAFKA_CONSUMER_GROUP=streamlake-bronze-writer

# ── Redis (local) ──────────────────────────────────────────────────
REDIS_CONNECTION_STRING=localhost:6379

# ── Redis Cloud (cloud) ────────────────────────────────────────────
# Get from Redis Cloud console > Connect > redis-cli
# REDIS_CONNECTION_STRING=redis-12345.c1.us-east-1-1.ec2.redns.redis-cloud.com:12345,password=xxx,ssl=true

# ── MLflow ─────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=mlruns

# ── FastAPI serving (Streamlit dashboard points here) ──────────────
# Local:  http://localhost:8000
# Cloud:  https://your-app.up.railway.app
API_URL=http://localhost:8000

# ── PostgreSQL (optional metadata store) ───────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=streamlake
POSTGRES_PASSWORD=streamlake
POSTGRES_DB=streamlake

# ── Grafana ────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
