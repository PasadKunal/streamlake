# ── MinIO (local S3) ───────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://localhost:9002

# S3 credentials for Delta Lake / boto3 (point to MinIO locally)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_ENDPOINT_URL=http://localhost:9002
AWS_DEFAULT_REGION=us-east-1

# ── Redpanda / Kafka (Phase 1) ─────────────────────────────────────
# For local Redpanda:
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081

# For Redpanda Cloud (replace with your cluster credentials):
# KAFKA_BOOTSTRAP_SERVERS=<your-cluster>.cloud.redpanda.com:9092
# KAFKA_SASL_USERNAME=<your-username>
# KAFKA_SASL_PASSWORD=<your-password>
# SCHEMA_REGISTRY_URL=https://<your-schema-registry>.cloud.redpanda.com

# ── Kafka Topics ───────────────────────────────────────────────────
KAFKA_TOPIC_EVENTS=streamlake.events.raw
KAFKA_CONSUMER_GROUP=streamlake-bronze-writer

# ── Delta Lake Paths ───────────────────────────────────────────────
DELTA_BRONZE_PATH=s3://streamlake-bronze/events
DELTA_SILVER_PATH=s3://streamlake-silver/events
DELTA_GOLD_PATH=s3://streamlake-gold
DELTA_QUARANTINE_PATH=s3://streamlake-silver/quarantine
DELTA_FEATURES_PATH=s3://streamlake-features

# ── Redis (Online Feature Store) ───────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── PostgreSQL (Metadata / Lineage / A/B results) ──────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=streamlake
POSTGRES_PASSWORD=streamlake
POSTGRES_DB=streamlake

# ── MLflow (Phase 5) ───────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000

# ── Grafana ────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ── Alerts (Phase 6) ───────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
